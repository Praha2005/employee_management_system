# pyenv
#   For a library or package, you might want to share your Python version
#   with the community and not personal development. Only uncomment if you
#   know what you are doing.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a windows machine, lock file might not be portable.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock
#   pdm local configuration
.pdm-python.path
.pdm-db/

# pipx
.pipx_filenames

# venv
#   Metadata for a virtual environment is typically not checked into source control
venv/
ENV/
env/
.env
.venv
pip-selfcheck.json

